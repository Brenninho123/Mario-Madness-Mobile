<?xml version="1.0" encoding="utf-8"?>
<project>

	<!-- ── App ── -->
	<app title="FNF: Mario's Madness" file="Mario" packageName="com.horror.mario" package="com.horror.mario" main="Main" version="2.0.1" company="ShadowMario" if="desktop" />
	<app title="FNF: Mario's Madness" file="Mario" packageName="com.horror.mario" package="com.horror.mario" main="Main" version="2.0.1" company="ShadowMario" if="mobile"  />

	<set name="APP_ID" value="0x0100f6c013bbc000" />

	<app preloader="flixel.system.FlxPreloader" />
	<set name="SWF_VERSION" value="11.8" />

	<!-- ── Window ── -->
	<window width="1280" height="720" fps="" background="#000000" hardware="true" vsync="false" />

	<window if="html5"   resizable="true" />
	<window if="desktop" orientation="landscape" fullscreen="false" resizable="true" vsync="false" />
	<window if="mobile"  orientation="landscape" fullscreen="true" width="0" height="0" resizable="false"
	        allow-shaders="true" require-shaders="true" allow-high-dpi="true" />
	<window if="switch"  orientation="landscape" fullscreen="true" width="0" height="0" resizable="true" />

	<!-- ── Android ── -->
	<android min-sdk-version="21" target-sdk-version="34" if="android" />

	<!-- ── iOS ── -->
	<ios deployment="14.0" if="ios" />

	<!-- ── Build dirs ── -->
	<set name="BUILD_DIR" value="export/debug"   if="debug" />
	<set name="BUILD_DIR" value="export/release" unless="debug" />
	<set name="BUILD_DIR" value="export/32bit"   if="32" />

	<!-- ── Source ── -->
	<classpath name="source" />

	<!-- ── Assets ── -->
	<assets path="assets/preload" rename="assets" exclude="*.ogg" if="web"     embed="true" />
	<assets path="assets/preload" rename="assets" exclude="*.mp3" unless="web" embed="true" />

	<!-- ── Feature flags ── -->
	<define name="MODS_ALLOWED"   if="desktop" />
	<define name="LUA_ALLOWED"    if="windows" />
	<define name="VIDEOS_ALLOWED" if="web || windows" unless="32" />

	<define name="PRELOAD_ALL"    unless="web" />
	<define name="NO_PRELOAD_ALL" unless="PRELOAD_ALL" />

	<!-- ── Libraries ── -->
	<library name="videos"  preload="true" />

	<section if="PRELOAD_ALL">
		<library name="songs"  preload="true" />
		<library name="shared" preload="true" />
	</section>

	<section if="NO_PRELOAD_ALL">
		<library name="songs"  preload="false" />
		<library name="shared" preload="false" />
	</section>

	<!-- ── Video codec ── -->
	<haxelib name="hxcodec" version="2.6.1" if="VIDEOS_ALLOWED" />
	<assets path="plugins/"      rename="" if="VIDEOS_ALLOWED windows" />
	<assets path="dlls/"         rename="" if="VIDEOS_ALLOWED windows" />
	<assets path="assets/videos" library="videos" if="VIDEOS_ALLOWED" embed="true" />

	<!-- ── Song / Shared ── -->
	<assets path="assets/songs"  library="songs"  exclude="*.ogg" if="web"     embed="true" />
	<assets path="assets/songs"  library="songs"  exclude="*.mp3" unless="web" embed="true" />
	<assets path="assets/shared" library="shared" exclude="*.ogg" if="web"     embed="true" />
	<assets path="assets/shared" library="shared" exclude="*.mp3" unless="web" embed="true" />

	<!-- ── Mods (desktop only) ── -->
	<assets path="example_mods" rename="mods" embed="false" if="MODS_ALLOWED" />
	<assets path="art/readme.txt" rename="do NOT readme.txt" />

	<!-- ── Fonts ── -->
	<assets path="assets/fonts" embed="true" />

	<!-- ── Mobile assets (no extraction) ── -->
	<section if="mobile">
		<assets path="assets/preload" rename="assets" exclude="*.mp3" embed="true" />
		<assets path="assets/songs"   library="songs"  exclude="*.mp3" embed="true" />
		<assets path="assets/shared"  library="shared" exclude="*.mp3" embed="true" />
		<assets path="assets/fonts"   embed="true" />
	</section>

	<!-- ── Haxelibs ── -->
	<haxelib name="flixel" />
	<haxelib name="flixel-addons" />
	<haxelib name="flixel-ui" />
	<haxelib name="hscript" />
	<haxelib name="linc_luajit"            if="LUA_ALLOWED" />
	<haxelib name="faxe"                   if="switch" />
	<haxelib name="discord_rpc"            if="desktop" />
	<haxelib name="extension-androidtools" if="android" />

	<!-- ── Haxedefines ── -->
	<haxedef name="FLX_NO_FOCUS_LOST_SCREEN" />
	<haxedef name="FLX_NO_DEBUG"             unless="debug" />
	<haxedef name="NAPE_RELEASE_BUILD"       unless="debug" />
	<haxedef name="no-deprecation-warnings" />

	<!-- ── Mobile defines ── -->
	<haxedef name="MOBILE_ALLOWED"       if="mobile" />
	<haxedef name="DISCORD_ALLOWED"      if="desktop" />
	<haxedef name="CHECK_FOR_UPDATES"    if="desktop" />
	<haxedef name="ACHIEVEMENTS_ALLOWED" unless="mobile" />

	<!-- ── Android permissions ── -->
	<section if="android">
		<permission android:name="android.permission.INTERNET" />
		<permission android:name="android.permission.VIBRATE" />
		<permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
		<permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
		<permission android:name="android.permission.READ_MEDIA_AUDIO" />
		<permission android:name="android.permission.READ_MEDIA_IMAGES" />
		<permission android:name="android.permission.READ_MEDIA_VIDEO" />
		<permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />
	</section>

	<!-- ── Icons ── -->
	<icon path="art/icon16.png" size="16" />
	<icon path="art/icon32.png" size="32" />
	<icon path="art/icon64.png" size="64" />
	<icon path="art/iconOG.png" />

</project>
